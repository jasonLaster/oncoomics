{
  "name": "diana-omics",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "fetch:phase1": "bun run scripts/fetch-phase1.ts",
    "fetch:raw-candidates": "bun run scripts/fetch-raw-candidate-metadata.ts",
    "audit:raw-tools": "bun run scripts/audit-raw-tools.ts",
    "build:raw-samplesheets": "bun run scripts/build-raw-samplesheets.ts",
    "smoke:raw": "bun run scripts/run-raw-smoke.ts",
    "build:alignment-smoke": "bun run scripts/build-alignment-smoke-assets.ts",
    "smoke:alignment": "bun run scripts/run-alignment-smoke.ts",
    "fetch:human-reference-smoke": "bun run scripts/fetch-human-reference-smoke-assets.ts",
    "smoke:human-reference": "bun run scripts/run-human-reference-smoke.ts",
    "build:panel": "bun run scripts/build-reference-panel.ts",
    "analyze:hrd": "bun run scripts/analyze-hrd.ts",
    "analyze:rna": "bun run scripts/build-rna-context.ts",
    "build:packet": "bun run scripts/build-reviewer-packet.ts",
    "verify:outputs": "bun run scripts/verify-outputs.ts",
    "verify:plan": "bun run scripts/verify-plan.ts",
    "verify:plan:online": "CHECK_URLS=1 bun run scripts/verify-plan.ts",
    "run:all": "bun run verify:plan && bun run fetch:phase1 && bun run fetch:raw-candidates && bun run audit:raw-tools && bun run build:raw-samplesheets && bun run smoke:raw && bun run build:alignment-smoke && bun run smoke:alignment && bun run fetch:human-reference-smoke && bun run smoke:human-reference && bun run build:panel && bun run analyze:hrd && bun run analyze:rna && bun run build:packet && bun run verify:outputs"
  }
}
