{
  "name": "diana-omics",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "fetch:phase1": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:phase1",
    "fetch:raw-candidates": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:raw-candidates",
    "audit:raw-tools": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics audit:raw-tools",
    "build:diana-template": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics build:diana-template",
    "verify:diana-raw": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics verify:diana-raw",
    "verify:orthogonal": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics verify:orthogonal",
    "stage:diana-raw": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics stage:diana-raw",
    "build:raw-samplesheets": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics build:raw-samplesheets",
    "smoke:raw": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics smoke:raw",
    "build:alignment-smoke": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics build:alignment-smoke",
    "smoke:alignment": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics smoke:alignment",
    "fetch:human-reference-smoke": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:human-reference-smoke",
    "smoke:human-reference": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics smoke:human-reference",
    "fetch:full-reference-smoke": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:full-reference-smoke",
    "smoke:full-reference": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics smoke:full-reference",
    "fetch:production-somatic": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:production-somatic",
    "smoke:production-somatic": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics smoke:production-somatic",
    "fetch:full-wes": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:full-wes",
    "benchmark:full-wes": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics benchmark:full-wes",
    "fetch:phase3-wgs": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics fetch:phase3-wgs",
    "validate:phase3-wgs": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics validate:phase3-wgs",
    "build:panel": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics build:panel",
    "analyze:hrd": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics analyze:hrd",
    "analyze:rna": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics analyze:rna",
    "build:packet": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics build:packet",
    "verify:outputs": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics verify:outputs",
    "verify:plan": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics verify:plan",
    "verify:plan:online": "CHECK_URLS=1 PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m diana_omics verify:plan",
    "py:lint": "${PYTHON_BIN:-/usr/bin/python3} -m ruff check py/src py/tests",
    "py:format": "${PYTHON_BIN:-/usr/bin/python3} -m ruff format py/src py/tests",
    "py:format:check": "${PYTHON_BIN:-/usr/bin/python3} -m ruff format --check py/src py/tests",
    "py:typecheck": "MYPYPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m mypy --config-file py/pyproject.toml py/src py/tests",
    "py:test": "PYTHONPATH=py/src ${PYTHON_BIN:-/usr/bin/python3} -m pytest py/tests",
    "typecheck": "bun run py:typecheck",
    "test": "bun run py:test",
    "run:all": "bun run verify:plan && bun run fetch:phase1 && bun run fetch:raw-candidates && bun run audit:raw-tools && bun run build:diana-template && bun run verify:diana-raw && bun run build:raw-samplesheets && bun run smoke:raw && bun run build:alignment-smoke && bun run smoke:alignment && bun run fetch:human-reference-smoke && bun run smoke:human-reference && bun run fetch:full-reference-smoke && bun run smoke:full-reference && bun run fetch:production-somatic && bun run smoke:production-somatic && bun run fetch:full-wes && bun run benchmark:full-wes && bun run fetch:phase3-wgs && bun run validate:phase3-wgs && bun run verify:orthogonal && bun run build:panel && bun run analyze:hrd && bun run analyze:rna && bun run build:packet && bun run verify:outputs"
  }
}
