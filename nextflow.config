params {
    workflow = 'quick'
    phase3_reads = null
    phase3_fetch_cpus = 4
    phase3_fetch_memory = '16 GB'
    phase3_fetch_concurrency = 2
    phase3_aria2_split = 1
    phase3_source_mode = 'ena_fastq'
    phase3_sra_aws_bucket = 'sra-pub-run-odp'
    sra_benchmark_runs = 'SRR7890824,SRR7890827'
    sra_benchmark_bytes = 1073741824
    sra_benchmark_parts = 1
    sra_benchmark_strategy = 'aws_s3api_range'
    sra_benchmark_matrix = null
    allow_full_wgs = false
    outdir = "${projectDir}/nextflow-out"
    python_bin = '/usr/bin/python3'
    repo_dir = projectDir.toString()
    container = 'diana-omics:local'
    aws_queue = null
    aws_spot_queue = null
    aws_ondemand_queue = null
    aws_region = 'us-east-1'
    aws_workdir = null
    aws_results_dir = null
    aws_job_role = null
    aws_logs_group = '/aws/batch/job'
    skip_wiki_checks = false
}

process {
    executor = 'local'
    errorStrategy = 'terminate'
}

profiles {
    local {
        process.executor = 'local'
    }

    docker {
        docker.enabled = true
        process.container = params.container
        params.repo_dir = '/opt/diana-omics'
        params.skip_wiki_checks = true
    }

    awsbatch {
        process.executor = 'awsbatch'
        process.container = params.container
        process.queue = params.aws_queue
        env.AWS_CA_BUNDLE = '/etc/ssl/certs/ca-certificates.crt'
        env.DIANA_OMICS_COMMAND_HEARTBEAT_SECONDS = '60'
        params.repo_dir = '/opt/diana-omics'
        aws.region = params.aws_region
        aws.batch.jobRole = params.aws_job_role
        aws.batch.logsGroup = params.aws_logs_group
        aws.batch.cliPath = '/opt/diana-aws/bin/aws'
        workDir = params.aws_workdir
        params.skip_wiki_checks = true
    }

    awsbatch_spot {
        process.executor = 'awsbatch'
        process.container = params.container
        process.queue = params.aws_spot_queue
        env.AWS_CA_BUNDLE = '/etc/ssl/certs/ca-certificates.crt'
        env.DIANA_OMICS_COMMAND_HEARTBEAT_SECONDS = '60'
        params.repo_dir = '/opt/diana-omics'
        aws.region = params.aws_region
        aws.batch.jobRole = params.aws_job_role
        aws.batch.logsGroup = params.aws_logs_group
        aws.batch.cliPath = '/opt/diana-aws/bin/aws'
        workDir = params.aws_workdir
        params.outdir = params.aws_results_dir
        params.skip_wiki_checks = true
    }

    awsbatch_ondemand {
        process.executor = 'awsbatch'
        process.container = params.container
        process.queue = params.aws_ondemand_queue
        env.AWS_CA_BUNDLE = '/etc/ssl/certs/ca-certificates.crt'
        env.DIANA_OMICS_COMMAND_HEARTBEAT_SECONDS = '60'
        params.repo_dir = '/opt/diana-omics'
        aws.region = params.aws_region
        aws.batch.jobRole = params.aws_job_role
        aws.batch.logsGroup = params.aws_logs_group
        aws.batch.cliPath = '/opt/diana-aws/bin/aws'
        workDir = params.aws_workdir
        params.outdir = params.aws_results_dir
        params.skip_wiki_checks = true
    }
}
