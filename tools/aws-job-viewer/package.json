{
  "name": "diana-aws-job-viewer",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=22.13.0"
  },
  "scripts": {
    "dev": "next dev --hostname 127.0.0.1",
    "viewer": "./scripts/start-local.sh",
    "build": "next build",
    "convex:codegen": "convex codegen",
    "convex:deploy": "convex deploy --cmd-url-env-var-name CONVEX_URL --cmd 'npm run build'",
    "convex:backfill-logs": "node scripts/backfill-convex-logs.mjs --full",
    "start": "next start",
    "test": "npm run build && npm run test:unit",
    "test:unit": "node --experimental-strip-types --test tests/*.test.mjs",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint app convex lib tests --ignore-pattern .next --ignore-pattern convex/_generated"
  },
  "dependencies": {
    "@aws-sdk/client-batch": "^3.1088.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1088.0",
    "@vercel/oidc": "^3.8.0",
    "@vercel/oidc-aws-credentials-provider": "^3.3.0",
    "convex": "^1.42.2",
    "next": "16.2.6",
    "react": "19.2.6",
    "react-dom": "19.2.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "4.2.1",
    "@types/node": "22.19.19",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "9.39.4",
    "eslint-config-next": "16.2.6",
    "tailwindcss": "4.2.1",
    "typescript": "5.9.3"
  },
  "overrides": {
    "postcss": "8.5.19"
  },
  "type": "module"
}
